# Model Provider Configuration
ACTIVE_PROVIDER=ollama
MODEL_NAME=gemma4:latest

# Ollama Configuration (Local/Remote)
OLLAMA_HOST=http://localhost:11434

# Ollama Cloud (optional - for cloud-hosted models)
# Get your API key from: https://ollama.com/cloud
# OLLAMA_API_KEY=your-ollama-cloud-key

# Alternative: Custom OpenAI-compatible endpoint (e.g., rsxermu666.cn)
# RSXERMU_BASE_URL=https://rsxermu666.cn
# RSXERMU_API_KEY=your-api-key
# RSXERMU_MODEL=gemma4:latest
