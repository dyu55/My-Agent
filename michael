#!/usr/bin/env python3
"""
MyAgent CLI entry point - Claude Code style coding agent

Usage:
    myagent                          # Start interactive CLI
    myagent "create TODO app"        # Execute single task
    myagent -m qwen2.5:9b           # Use specific model

Interactive mode:
    >>> Implement user login functionality
    >>> Add a registration page
    >>> /task Add payment module

Commands:
    /task <desc>    Execute task
    /edit <file>    View file
    /run <cmd>      Execute command
    /test           Run pytest
    /git <args>     Git operations
    /status         Show status
    /help           Help
    /exit           Exit
"""

import os
import sys
from pathlib import Path

# Add project root to path
PROJECT_ROOT = Path(__file__).parent.resolve()
sys.path.insert(0, str(PROJECT_ROOT))


def load_env_file(path: Path) -> None:
    """Load environment variables from .env file."""
    if not path.exists():
        return
    for line in path.read_text(encoding="utf-8").splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        os.environ.setdefault(key.strip(), value.strip())


def get_cli_name() -> str:
    """Get the CLI name from config or use default."""
    config_dir = Path.home() / ".config" / "myagent"
    config_file = config_dir / "config.json"

    if config_file.exists():
        import json
        with open(config_file, "r") as f:
            config = json.load(f)
            return config.get("cli_name", "myagent")

    # First run - use default name "myagent"
    print("""
╔════════════════════════════════════════════════════════════════════════════╗
║                                                                            ║
║   Welcome to MyAgent CLI!                                                  ║
║                                                                            ║
║   Default CLI name: myagent                                                ║
║   To customize, edit: ~/.config/myagent/config.json                        ║
║                                                                            ║
╚════════════════════════════════════════════════════════════════════════════╝
""")

    name = "myagent"

    # Save config
    config_dir.mkdir(parents=True, exist_ok=True)
    with open(config_file, "w") as f:
        import json
        json.dump({"cli_name": name, "version": "1.0"}, f)

    return name


def get_base_url(provider: str) -> str:
    """Get base URL based on provider."""
    if provider == "ollama":
        return os.environ.get("OLLAMA_HOST", "http://192.168.0.124:11434")
    elif provider == "rsxermu":
        return os.environ.get("RSXERMU_BASE_URL", "https://rsxermu666.cn")
    return "http://localhost:11434"


def main():
    """Main entry point."""
    # Load environment
    load_env_file(PROJECT_ROOT / ".env")

    # Get CLI name
    cli_name = get_cli_name()

    import argparse

    parser = argparse.ArgumentParser(
        prog=cli_name,
        description=f"{cli_name} - Local Coding Agent (Claude Code style)",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""
Examples:
    {cli_name}                          # Interactive CLI
    {cli_name} "Create a TODO app"    # Execute single task
    {cli_name} -m qwen2.5:9b          # Use specific model
    {cli_name} --classic               # Use classic CLI mode

Commands:
    /task <desc>    Execute task
    /edit <file>    View file
    /run <cmd>      Execute command
    /test           Run pytest
    /git <args>     Git operations
    /status         Show status
    /help           Help
    /exit           Exit
        """,
    )

    parser.add_argument(
        "task",
        nargs="?",
        default=None,
        help="Task to execute",
    )
    parser.add_argument(
        "--model", "-m",
        default=os.environ.get("MODEL_NAME", "gemma4:latest"),
        help="Model to use",
    )
    parser.add_argument(
        "--provider", "-p",
        choices=["ollama", "rsxermu"],
        default=os.environ.get("ACTIVE_PROVIDER", "ollama"),
        help="Provider to use",
    )
    parser.add_argument(
        "--base-url", "-u",
        default=None,
        help="API Base URL",
    )
    parser.add_argument(
        "--workspace", "-w",
        default="workspace",
        help="Workspace directory",
    )
    parser.add_argument(
        "--classic", "-c",
        action="store_true",
        help="Use classic CLI mode",
    )

    args = parser.parse_args()

    # Determine base URL
    base_url = args.base_url or get_base_url(args.provider)

    # Create workspace
    workspace = Path(args.workspace).resolve()
    workspace.mkdir(parents=True, exist_ok=True)

    # Execute single task
    if args.task:
        from agent import AgentEngine
        from agent.engine import AgentConfig

        config = AgentConfig(
            workspace=workspace,
            model=args.model,
            provider=args.provider,
            base_url=base_url,
            api_key=os.environ.get("RSXERMU_API_KEY"),
        )

        print(f"🚀 Executing task: {args.task}")
        print(f"   Model: {args.model}")
        print(f"   Provider: {args.provider}")
        print()

        try:
            agent = AgentEngine(config)
            result = agent.run(args.task)
            print(f"\n✨ Done: {result}")
        except Exception as e:
            print(f"\n❌ Error: {e}")
            return 1
        return 0

    # Interactive mode
    if args.classic:
        # Classic CLI mode
        from cli import CLIInterface

        cli = CLIInterface(
            workspace=workspace,
            model=args.model,
            provider=args.provider,
            base_url=base_url,
            api_key=os.environ.get("RSXERMU_API_KEY"),
        )
        try:
            cli.run()
        except KeyboardInterrupt:
            print("\nGoodbye!")
    else:
        # Claude Code style CLI
        from cli.michael import MichaelCLI

        cli = MichaelCLI(
            workspace=workspace,
            model=args.model,
            provider=args.provider,
            base_url=base_url,
            api_key=os.environ.get("RSXERMU_API_KEY"),
            cli_name=cli_name,
        )
        try:
            cli.run()
        except KeyboardInterrupt:
            print("\nGoodbye!")

    return 0


if __name__ == "__main__":
    sys.exit(main())